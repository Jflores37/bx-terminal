# Copy to .env and fill in the anon public key, then `npm run dev`.
#
# WARNING: VITE_ vars are inlined into the public client bundle at build time.
# They are NOT secret — anyone can read them in the deployed site. Only ever put
# the *anon* (public) key here; NEVER the service_role key. Real access control
# must be enforced by Supabase Row Level Security, not by hiding this key.
VITE_SUPABASE_URL=https://wefobwdspqzxbesbnzoc.supabase.co
VITE_SUPABASE_ANON_KEY=
